# Common flags
build --enable_platform_specific_config
build --incompatible_strict_action_env

# Shell configuration
build --action_env=SHELL=/bin/bash
build --action_env=PATH=/usr/local/bin:/usr/bin:/bin

# Performance
build --jobs=auto
build --worker_sandboxing

# Output
build --show_timestamps
build --color=yes

# Cache
build --disk_cache=~/.cache/bazel-fedora-distroless

# Linux
build:linux --cxxopt=-std=c++17

# macOS
build:macos --cxxopt=-std=c++17

# CI
build:ci --show_progress_rate_limit=30
build:ci --curses=no
build:ci --color=yes
